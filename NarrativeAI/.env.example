# AI Narrative Continuity Companion environment variables
# Copy this to .env and fill in your IBM credentials.

# IBM watsonx.ai API key
WATSONX_APIKEY=your_key_here

# watsonx.ai project information
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://your-watsonx-url

# Cloudant credentials
CLOUDANT_API_KEY=your_cloudant_api_key_here
CLOUDANT_URL=https://your-cloudant-url

# Watson NLU credentials
NLU_API_KEY=your_nlu_api_key_here
NLU_URL=https://your-nlu-url
